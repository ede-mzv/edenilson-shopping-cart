{
  "info": {
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f23456789012",
    "name": "Edenilson Shopping Cart",
    "description": "Microservices-based shopping cart API collection.\n\nServices:\n- Product Service (8081): Proxy to FakeStoreAPI\n- Order Service (8082): Order management with JWT auth\n- Payment Service (8083): Payment simulation with JWT auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Product Service",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_url}}/api/products",
              "host": ["{{product_url}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Get All Products (with limit & sort)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_url}}/api/products?limit=5&sort=desc",
              "host": ["{{product_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "sort", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_url}}/api/products/1",
              "host": ["{{product_url}}"],
              "path": ["api", "products", "1"]
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_url}}/api/products/categories",
              "host": ["{{product_url}}"],
              "path": ["api", "products", "categories"]
            }
          }
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_url}}/api/products/category/electronics",
              "host": ["{{product_url}}"],
              "path": ["api", "products", "category", "electronics"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('jwt_token', jsonData.token);",
                  "    pm.test('Token saved', function () {",
                  "        pm.expect(jsonData.token).to.not.be.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstName\": \"Edenilson\",\n    \"lastName\": \"Test\",\n    \"email\": \"edenilson@test.com\",\n    \"phone\": \"+503 7000-0000\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{order_url}}/api/auth/register",
              "host": ["{{order_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('jwt_token', jsonData.token);",
                  "    pm.test('Token saved', function () {",
                  "        pm.expect(jsonData.token).to.not.be.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"edenilson@test.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{order_url}}/api/auth/login",
              "host": ["{{order_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('order_id', jsonData.id);",
                  "    pm.environment.set('customer_id', jsonData.customer.id);",
                  "    pm.test('Order ID saved', function () {",
                  "        pm.expect(jsonData.id).to.not.be.undefined;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"customerId\": {{customer_id}},\n    \"items\": [\n        {\n            \"productId\": 1,\n            \"quantity\": 2\n        },\n        {\n            \"productId\": 3,\n            \"quantity\": 1\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{order_url}}/api/orders",
              "host": ["{{order_url}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{order_url}}/api/orders",
              "host": ["{{order_url}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{order_url}}/api/orders/{{order_id}}",
              "host": ["{{order_url}}"],
              "path": ["api", "orders", "{{order_id}}"]
            }
          }
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"customerId\": {{customer_id}},\n    \"items\": [\n        {\n            \"productId\": 2,\n            \"quantity\": 3\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{order_url}}/api/orders/{{order_id}}",
              "host": ["{{order_url}}"],
              "path": ["api", "orders", "{{order_id}}"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"CONFIRMED\"\n}"
            },
            "url": {
              "raw": "{{order_url}}/api/orders/{{order_id}}/status",
              "host": ["{{order_url}}"],
              "path": ["api", "orders", "{{order_id}}", "status"]
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{order_url}}/api/orders/{{order_id}}",
              "host": ["{{order_url}}"],
              "path": ["api", "orders", "{{order_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Process Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('payment_id', jsonData.id);",
                  "    pm.test('Payment ID saved', function () {",
                  "        pm.expect(jsonData.id).to.not.be.undefined;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"orderId\": {{order_id}},\n    \"paymentMethod\": \"CREDIT_CARD\"\n}"
            },
            "url": {
              "raw": "{{payment_url}}/api/payments",
              "host": ["{{payment_url}}"],
              "path": ["api", "payments"]
            }
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{payment_url}}/api/payments/{{payment_id}}",
              "host": ["{{payment_url}}"],
              "path": ["api", "payments", "{{payment_id}}"]
            }
          }
        },
        {
          "name": "Get Payment by Order ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{payment_url}}/api/payments/order/{{order_id}}",
              "host": ["{{payment_url}}"],
              "path": ["api", "payments", "order", "{{order_id}}"]
            }
          }
        },
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{payment_url}}/api/payments",
              "host": ["{{payment_url}}"],
              "path": ["api", "payments"]
            }
          }
        }
      ]
    },
